# SFTM - Street Fighter: The Movie (Incredible Technologies itech32)
# JTFRAME macro configuration. Evaluated with `jtframe cfgstr sftm`.

CORENAME=SFTM
# jtframe mem generates jtsftm_game_sdram.v (jt+core+_game_sdram).
# GAMETOP must match that name so jtframe files syn adds the right file to files.qip.
GAMETOP=jtsftm_game_sdram

# Measured refresh (itech32 P/N 1083: VSync 59.7612 Hz)
JTFRAME_RATE=59.76

# Active video dimensions (MAME: visarea 0-383 h, 8-255 v)
JTFRAME_WIDTH=384
JTFRAME_HEIGHT=248

# 15-bit palette -> 5 bits per colour channel
JTFRAME_COLORW=5

# Horizontal game (do NOT define JTFRAME_VERTICAL)

# 6 action buttons (LP MP HP LK MK HK)
JTFRAME_BUTTONS=6

# --- Memory ------------------------------------------------------------------
# ~36 MB of ROM (see cfg/mem.yaml). Needs the 4 SDRAM banks AND the 128 MB
# module, because 4 x 8 MB = 32 MB on the standard module is not enough.
JTFRAME_SDRAM_BANKS
# 128 MB SDRAM module (4 x 32 MB banks). Confirm macro name against the
# installed JTFRAME version's doc/sdram.md; JTFRAME_SDRAM128 is the typical
# MiSTer 128 MB macro. Bank 2 needs a 32 MB bank for the 32 MB grom region.
JTFRAME_SDRAM128
#
# SDRAM bank byte-offset boundaries in the ROM download stream.
# Download order: BA0 (prog+snd), BA1 (srom), BA2 (grom), BA3 (grm3).
# maindata=1MB(0x100000) soundcpu=0x50000(pad 0x10000+ROM 0x40000)
# ensoniq.0=2MB(0x200000) ensoniq.3=512KB(0x80000)
# grom rm0+rm1=32MB(0x2000000) grom grm3=512KB(0x80000)
JTFRAME_BA1_START=0x150000
JTFRAME_BA2_START=0x3D0000
JTFRAME_BA3_START=0x23D0000
#
# NVRAM (0x600000-0x61ffff) is on-chip BRAM inside sftm_main for now; SD-card
# persistence (JTFRAME ioctl save/restore) is deferred - see cfg/mem.yaml.

[mister]
# OSD extras for MiSTer
JTFRAME_OSD_VOL
JTFRAME_CHEAT
