# Standalone linux/amd64 image for MiSTer synthesis.
#
# Uses Quartus Prime Lite 21.1.1 (2022-era binary, Rosetta 2 compatible).
# Quartus 17.1 (2017) fails on Apple Silicon with "rosetta error: bss_size overflow".
# On Apple Silicon this runs via Rosetta 2; on x86_64 Linux it runs natively.
#
# Prerequisites: place these in docker/quartus-installers/ first:
#   QuartusLiteSetup-21.1.0.842-linux.run  (1.7 GB)
#   cyclonev-21.1.0.842.qdz                (600 MB)
# See docker/quartus-installers/README.md for download instructions.
#
# Build (one time, ~15 min):
#   docker build --platform linux/amd64 -t sftm-quartus \
#       -f docker/Dockerfile.quartus docker/
#
# Re-synthesise:
#   ./docker/run-synth.sh

FROM --platform=linux/amd64 ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# ---- All packages in one layer (toolchain + Quartus 21.1 runtime) ----
# Quartus 21.1 links Qt5, glib, X11/GL. Ubuntu 24.04 uses the t64 ABI for glib.
RUN apt-get update && apt-get install -y --no-install-recommends \
    iverilog \
    ghdl-llvm \
    verilator \
    git \
    make \
    python3 \
    python3-pip \
    wget \
    curl \
    ca-certificates \
    xz-utils \
    build-essential \
    zlib1g-dev \
    libxft2 \
    libxext6 \
    libxrender1 \
    libxtst6 \
    libxi6 \
    libncurses6 \
    libpng16-16 \
    libglib2.0-0t64 \
    libsm6 \
    libice6 \
    libx11-6 \
    libxcb1 \
    libxkbcommon0 \
    libfreetype6 \
    libfontconfig1 \
    libudev1 \
    libgl1 \
    libegl1 \
    libglx0 \
    gawk \
    && rm -rf /var/lib/apt/lists/*

# Go 1.23 (for jtframe binary)
ARG GO_VERSION=1.23.5
RUN wget -q "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" -O /tmp/go.tgz \
    && tar -C /usr/local -xzf /tmp/go.tgz \
    && rm /tmp/go.tgz
ENV PATH="/usr/local/go/bin:${PATH}"

# JTFRAME environment (same as main Dockerfile)
ENV JTROOT=/workspace
ENV JTFRAME=/workspace/modules/jtframe
ENV CORES=/workspace/cores
ENV MODULES=/workspace/modules
ENV JTBIN=/workspace/jtbin
ENV ROM=/workspace/rom
ENV MRA=/workspace/jtbin/mra
ENV TARGET=mister
ENV PATH="/workspace/modules/jtframe/bin:${PATH}"

# ---- Quartus Prime Lite 21.1.1 ----
# Files must be in docker/quartus-installers/ — see README.md there.
# In Quartus 21.x, `quartus_sh --install` was removed. Device support is
# installed by placing the .qdz in the same directory as the setup .run file
# before running the installer; it auto-detects and includes device support.
COPY quartus-installers/QuartusLiteSetup-21.1.0.842-linux.run /tmp/qinstall/QuartusLiteSetup.run
COPY quartus-installers/cyclonev-21.1.0.842.qdz /tmp/qinstall/cyclonev-21.1.0.842.qdz

# Install Quartus + Cyclone V device support in one step
RUN chmod +x /tmp/qinstall/QuartusLiteSetup.run && \
    /tmp/qinstall/QuartusLiteSetup.run \
        --mode unattended \
        --unattendedmodeui none \
        --installdir /opt/intelFPGA_lite/21.1 \
        --disable-components quartus_help,questa_fse,questa_fe \
        --accept_eula 1 && \
    rm -rf /tmp/qinstall

ENV PATH="/opt/intelFPGA_lite/21.1/quartus/bin:${PATH}"
ENV QUARTUS_ROOTDIR="/opt/intelFPGA_lite/21.1/quartus"

# Reuse the same entrypoint to auto-clone/build jtframe on first run
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

WORKDIR /workspace
ENTRYPOINT ["/entrypoint.sh"]
CMD ["/bin/bash"]
